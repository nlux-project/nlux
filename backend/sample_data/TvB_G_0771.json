  "referred_to_by": [
    {
      "type": "LinguisticObject",
      "content": "This is a portrait etching by Karel Dujardin (c. 1626–1678), depicting the Amsterdam poet and glazier Jan Vos (1612–1667) half-length, facing slightly right, holding a rolled paper or parchment in his left hand. The print was created as the frontispiece portrait for the second volume of Vos's collected poems, *Alle de gedichten* (Amsterdam, 1662). Below the portrait is a four-line laudatory poem by Joost van den Vondel. The print exists in at least 3–4 states; later states include biographical text about Vos's role in the 1648 Peace of Munster celebrations.",
      "classified_as": [
        {
          "id": "http://vocab.getty.edu/aat/300411780",
          "_label": "description"
        }
