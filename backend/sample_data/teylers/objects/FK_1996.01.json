  "referred_to_by": [
    {
      "type": "LinguisticObject",
      "content": "This is a Klankanalysator (Sound Analyzer), after Rudolph Koenig — the world's first acoustic spectrum analyzer. The instrument uses a bank of Helmholtz resonators connected to manometric flame capsules and a rotating mirror to make the harmonic components of complex sounds visible. When a sound (voice, musical instrument, etc.) is directed at the resonators, each one tuned to a different frequency vibrates in sympathy with its corresponding partial tone. These vibrations modulate gas flames via thin membranes, and the resulting flame fluctuations — invisible to the naked eye due to their speed — become visible as saw-toothed patterns of light when observed in a rotating four-sided mirror. The instrument is, in essence, the 19th-century equivalent of an oscilloscope or modern spectrum analyzer.",
      "classified_as": [
        {
          "id": "http://vocab.getty.edu/aat/300411780",
          "_label": "description"
        }
      ],
