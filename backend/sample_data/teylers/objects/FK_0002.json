  "referred_to_by": [
    {
      "type": "LinguisticObject",
      "content": "This is a standard measuring ruler (standaardmaatlat) made by Benjamin Ayres (active 1731–c. 1775), an English-born instrument maker established in Amsterdam. The ruler is a conversion tool comparing multiple concurrent European measurement systems — English, French, Rhineland, Amsterdam, and Holland measures — in mahogany with brass fittings. Made for or by appointment to the Prince of Orange and the Admiralty of Amsterdam, it represents the chaotic state of European metrology before the adoption of the metric system.",
      "classified_as": [
        {
          "id": "http://vocab.getty.edu/aat/300411780",
          "_label": "description"
        }
      ],
