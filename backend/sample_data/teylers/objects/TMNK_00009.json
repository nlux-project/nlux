  "referred_to_by": [
    {
      "type": "LinguisticObject",
      "content": "This is a rare **gold** example of a \"Judenmedaille\" (Prague Jewish medal) depicting Empress Eleanor of Portugal (1434–1467), wife of Emperor Frederick III. It belongs to a well-documented series of pseudo-medieval cast medals produced in Prague c. 1600–1650 to glorify the Habsburg dynasty's ancestry. The medal features Eleanor enthroned in full imperial regalia on the obverse, with a rose design on the reverse accompanied by Latin verses praising her virtue. Gold examples of this series are described as \"particularly rare\" in the numismatic literature; no other gold example of the Eleanor subject has been identified at auction.",
      "classified_as": [
        {
          "id": "http://vocab.getty.edu/aat/300411780",
          "_label": "description"
        }
      ],
