  "referred_to_by": [
    {
      "type": "LinguisticObject",
      "content": "\"Drie tulpen\" (Three Tulips) is a large-format watercolor drawing by Maria Sibylla Merian (1647–1717) on parchment, dated ca. 1670–1675. It depicts three tulips rendered with exceptional botanical precision, executed in pencil, colored brush, black brush, grey brush, and black pen. The sheet bears multiple handwritten inscriptions including the artist's own signature variants. It belongs to a category of luxury commercial drawings on parchment that Merian produced for the art market during her Nuremberg years (1670–1685). The work is cataloged as a \"Topstuk\" (masterpiece) by the museum.\n\n---",
      "classified_as": [
